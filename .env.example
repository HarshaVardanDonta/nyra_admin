# API base URL (no trailing slash). For browser access, the backend must include your admin origin in
# CORS_ALLOWED_ORIGINS (e.g. https://admin.nccppl.com for production).
#
# When the backend runs with ENVIRONMENT=dev, routes live under `/dev`. Set the same prefix here:
# VITE_API_PATH_PREFIX=/dev
# For production API (no path prefix), leave VITE_API_PATH_PREFIX unset or empty.
#
# Development (direct to API): browser hits the backend; DevTools shows http://localhost:8080.
# The API must allow CORS from http://localhost:5173 (or your dev origin).
# VITE_API_BASE_URL=http://localhost:8080
# VITE_API_PATH_PREFIX=/dev
# VITE_API_PROXY_TARGET=http://localhost:8080
#
# Development (proxy): leave VITE_API_BASE_URL empty — DevTools shows http://localhost:5173
# because requests are same-origin. Vite proxies either `/dev` (if VITE_API_PATH_PREFIX=/dev) or
# `/api` and `/healthz` to VITE_API_PROXY_TARGET (no API CORS needed).
# VITE_API_BASE_URL=
# VITE_API_PATH_PREFIX=/dev
# VITE_API_PROXY_TARGET=http://localhost:8080
#
# Production: required — full public API URL.
# Docker: this file must define VITE_API_BASE_URL before `docker compose build`; it is passed as a
# build-arg (see docker-compose.yml). .env is not copied into the image (.dockerignore).
# VITE_API_BASE_URL=https://api.example.com

VITE_API_BASE_URL=http://localhost:8080
VITE_API_PATH_PREFIX=/dev
VITE_API_PROXY_TARGET=http://localhost:8080
