# API base URL (no trailing slash). For browser access, the backend must include your admin origin in
# CORS_ALLOWED_ORIGINS (e.g. https://admin.nccppl.com for production).
#
# Dev vs prod APIs use different hosts (e.g. api-dev vs api); leave VITE_API_PATH_PREFIX empty unless
# you intentionally mount the API under a path prefix.
#
# Development (direct to API): browser hits the backend; DevTools shows http://localhost:8080.
# The API must allow CORS from http://localhost:5173 (or your dev origin).
# VITE_API_BASE_URL=http://localhost:8080
# VITE_API_PROXY_TARGET=http://localhost:8080
#
# Development (proxy): leave VITE_API_BASE_URL empty — DevTools shows http://localhost:5173
# because requests are same-origin. Vite proxies `/api` and `/healthz` to VITE_API_PROXY_TARGET.
# VITE_API_BASE_URL=
# VITE_API_PROXY_TARGET=http://localhost:8080
#
# Production: required — full public API URL.
# Docker (VPS): place this file beside `docker-compose.yml` before `docker compose build admin`.
# Compose passes VITE_MSG91_* below as build-args (they are not read from a runtime .env inside nginx).
# Without them, the image uses legacy /otp/verify and the API must set a real MSG91_TEMPLATE_ID.
# VITE_API_BASE_URL=https://api.example.com

VITE_API_BASE_URL=http://localhost:8080
VITE_API_PROXY_TARGET=http://localhost:8080

# Admin login: MSG91 OTP Widget (optional). VITE_* only affects the browser bundle; the API host (e.g. api.nccppl.com)
# must also set MSG91_WIDGET_ID and MSG91_WIDGET_AUTH_TOKEN on the server or widget routes return 503 WIDGET_PROXY_UNAVAILABLE.
# Same values as below / MSG91 panel. Backend also needs MSG91_AUTH_KEY for POST .../widget-session.
# VITE_MSG91_WIDGET_ID=366379714f54303033303633
# Client token only if NOT using server proxy (desktop browsers; mobile will often fail with web-only widgets):
# VITE_MSG91_WIDGET_AUTH_TOKEN=

# Default on: widget send/verify/retry go through POST /api/v1/auth/otp/widget/* (fixes “Mobile requests are not allowed…” on phones).
# VITE_MSG91_WIDGET_USE_SERVER_PROXY=false

# Use legacy /api/v1/auth/otp/send + /verify (e.g. OTP_PROVIDER=dummy with 111111) — set false for local dev.
# VITE_USE_MSG91_WIDGET=false
