# API base URL (no trailing slash).
#
# Development (recommended): leave empty so requests go to the Vite dev server and
# are proxied to the backend — avoids CORS. Set VITE_API_PROXY_TARGET to your API.
# VITE_API_BASE_URL=
# VITE_API_PROXY_TARGET=http://localhost:8080
#
# Development (direct to API): full URL — backend must allow CORS from the dev origin.
# VITE_API_BASE_URL=http://localhost:8080
#
# Production: required — full public API URL.
# VITE_API_BASE_URL=https://api.example.com

VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:8080
